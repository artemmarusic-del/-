# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/diabetes_app?schema=public"

# Long random string used to sign JWTs. Generate e.g. with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"

# Port the API server listens on
PORT=4000

# Origin of the frontend, used for CORS + cookie settings
CLIENT_URL="http://localhost:5173"

# "production" enables secure cookies (requires HTTPS)
NODE_ENV="development"
