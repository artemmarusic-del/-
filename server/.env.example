# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/diabetes_app?schema=public"

# Long random string used to sign JWTs. Generate e.g. with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"

# Port the API server listens on
PORT=4000

# Origin of the frontend, used for CORS + cookie settings
CLIENT_URL="http://localhost:5173"

# "production" enables secure cookies (requires HTTPS)
NODE_ENV="development"

# Public address of the app — used to build links inside emails
APP_URL="https://xe-dnevnik.onrender.com"

# SMTP for outgoing mail (password reset). If SMTP_HOST is empty, the reset
# link is printed to the server log instead of being emailed.
# Example for Gmail (requires an App Password, not the account password):
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="XEdnevnik@gmail.com"
SMTP_PASS="app-password-goes-here"
SMTP_FROM="ХЕ.Дневник <XEdnevnik@gmail.com>"
